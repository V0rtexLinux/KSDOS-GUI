; =============================================================================
; KERNEL32.DLL - Windows 32 Kernel API (16-bit Real Mode)
; Core kernel functions for memory management, file I/O, etc.
; =============================================================================

org 0x1000

; ---- KERNEL32 header ----
db 'KRN ', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dw kernel32_start              ; Entry point (16-bit offset)
dw kernel32_end - kernel32_start  ; Size
dd 0x00000000                  ; Reserved

; ---- Function table ----
function_table:
    dw kernel32_get_version      ; Function 0: Get version
    dw kernel32_get_module_handle ; Function 1: Get module handle
    dw kernel32_get_proc_address ; Function 2: Get procedure address
    dw kernel32_exit_process     ; Function 3: Exit process
    dw kernel32_get_current_process ; Function 4: Get current process
    dw kernel32_get_current_thread ; Function 5: Get current thread
    dw kernel32_sleep             ; Function 6: Sleep
    dw kernel32_get_tick_count   ; Function 7: Get tick count
    dw kernel32_heap_create      ; Function 8: Create heap
    dw kernel32_heap_alloc       ; Function 9: Allocate from heap
    dw kernel32_heap_free        ; Function 10: Free from heap
    dw kernel32_virtual_alloc    ; Function 11: Virtual alloc
    dw kernel32_virtual_free    ; Function 12: Virtual free
    dw kernel32_create_file      ; Function 13: Create file
    dw kernel32_read_file        ; Function 14: Read file
    dw kernel32_write_file       ; Function 15: Write file
    dw kernel32_close_handle     ; Function 16: Close handle

function_count equ 17

; ---- Data structures ----
heap_list       dw 0
file_handle     dw 0
tick_counter    dw 0
process_id      dw 1
thread_id       dw 1

kernel32_start:
    ; Initialize KERNEL32
    call kernel32_init
    
    ; Return success
    xor ax, ax
    ret

; =============================================================================
; kernel32_init: Initialize KERNEL32 library
; =============================================================================
kernel32_init:
    push ax
    push si
    
    ; Initialize tick counter
    mov [tick_counter], 0
    
    ; Initialize process and thread IDs
    mov [process_id], 1
    mov [thread_id], 1
    
    ; Display initialization message
    mov si, kernel32_init_msg
    call kernel32_print_string
    
    pop si
    pop ax
    ret

; =============================================================================
; kernel32_get_version: Get KSDOS version
; Output: AX = version (major in AH, minor in AL)
; =============================================================================
kernel32_get_version:
    mov ax, 0x0200    ; Version 2.0
    ret

; =============================================================================
; kernel32_get_module_handle: Get module handle
; Input: SI = module name pointer
; Output: AX = module handle (or 0 if not found)
; =============================================================================
kernel32_get_module_handle:
    ; Simple implementation - return current process handle
    mov ax, [process_id]
    ret

; =============================================================================
; kernel32_get_proc_address: Get procedure address
; Input: SI = module handle, DI = procedure name pointer
; Output: AX = procedure address (or 0 if not found)
; =============================================================================
kernel32_get_proc_address:
    ; Simple implementation - return dummy address
    mov ax, 0x1000
    ret

; =============================================================================
; kernel32_exit_process: Exit current process
; Input: AX = exit code
; =============================================================================
kernel32_exit_process:
    ; Return to system
    mov ah, 0x4C
    int 0x21
    ret

; =============================================================================
; kernel32_get_current_process: Get current process ID
; Output: AX = process ID
; =============================================================================
kernel32_get_current_process:
    mov ax, [process_id]
    ret

; =============================================================================
; kernel32_get_current_thread: Get current thread ID
; Output: AX = thread ID
; =============================================================================
kernel32_get_current_thread:
    mov ax, [thread_id]
    ret

; =============================================================================
; kernel32_sleep: Sleep for specified milliseconds
; Input: AX = milliseconds
; =============================================================================
kernel32_sleep:
    push ax
    push bx
    push cx
    push dx
    
    ; Convert milliseconds to timer ticks (approximately)
    mov bx, ax
    shr bx, 4      ; Divide by 16 (rough approximation)
    
    ; Simple delay loop
.delay_loop:
    mov cx, 0xFFFF
.inner_delay:
    loop .inner_delay
    dec bx
    jnz .delay_loop
    
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; =============================================================================
; kernel32_get_tick_count: Get system tick count
; Output: AX = tick count
; =============================================================================
kernel32_get_tick_count:
    mov ax, [tick_counter]
    ret

; =============================================================================
; kernel32_heap_create: Create heap
; Input: AX = initial size
; Output: AX = heap handle (or 0 if failed)
; =============================================================================
kernel32_heap_create:
    push bx
    push si
    
    ; Simple heap implementation
    mov bx, ax
    mov si, [heap_list]
    
    ; Add to heap list (simplified)
    mov [heap_list], si
    
    ; Return heap handle
    mov ax, si
    
    pop si
    pop bx
    ret

; =============================================================================
; kernel32_heap_alloc: Allocate from heap
; Input: AX = heap handle, BX = size
; Output: AX = pointer (or 0 if failed)
; =============================================================================
kernel32_heap_alloc:
    push bx
    push cx
    
    ; Simple allocation - return dummy address
    mov cx, bx
    mov ax, 0x8000    ; Dummy heap address
    
    pop cx
    pop bx
    ret

; =============================================================================
; kernel32_heap_free: Free from heap
; Input: AX = heap handle, BX = pointer
; =============================================================================
kernel32_heap_free:
    ; Simple implementation - do nothing
    ret

; =============================================================================
; kernel32_virtual_alloc: Allocate virtual memory
; Input: AX = size
; Output: AX = pointer (or 0 if failed)
; =============================================================================
kernel32_virtual_alloc:
    ; Simple implementation - return dummy address
    mov ax, 0x9000
    ret

; =============================================================================
; kernel32_virtual_free: Free virtual memory
; Input: AX = pointer
; =============================================================================
kernel32_virtual_free:
    ; Simple implementation - do nothing
    ret

; =============================================================================
; kernel32_create_file: Create or open file
; Input: SI = filename pointer, AX = access mode
; Output: AX = file handle (or -1 if failed)
; =============================================================================
kernel32_create_file:
    push ax
    push bx
    push cx
    push dx
    
    ; Use DOS file functions
    mov ah, 0x3D        ; Open file
    mov al, 0x02        ; Read/write access
    int 0x21
    jc .error
    
    ; Success - save file handle
    mov [file_handle], ax
    jmp .done
    
.error:
    mov ax, 0xFFFF      ; Error indicator
    
.done:
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; =============================================================================
; kernel32_read_file: Read from file
; Input: AX = file handle, BX = buffer pointer, CX = bytes to read
; Output: AX = bytes read (or -1 if error)
; =============================================================================
kernel32_read_file:
    push bx
    push cx
    push dx
    
    ; Use DOS file functions
    mov ah, 0x3F        ; Read from file
    mov bx, [file_handle]  ; File handle
    int 0x21
    jc .error
    
    ; Success
    jmp .done
    
.error:
    mov ax, 0xFFFF      ; Error indicator
    
.done:
    pop dx
    pop cx
    pop bx
    ret

; =============================================================================
; kernel32_write_file: Write to file
; Input: AX = file handle, BX = buffer pointer, CX = bytes to write
; Output: AX = bytes written (or -1 if error)
; =============================================================================
kernel32_write_file:
    push bx
    push cx
    push dx
    
    ; Use DOS file functions
    mov ah, 0x40        ; Write to file
    mov bx, [file_handle]  ; File handle
    int 0x21
    jc .error
    
    ; Success
    jmp .done
    
.error:
    mov ax, 0xFFFF      ; Error indicator
    
.done:
    pop dx
    pop cx
    pop bx
    ret

; =============================================================================
; kernel32_close_handle: Close file handle
; Input: AX = file handle
; Output: AX = 0 if success, -1 if error
; =============================================================================
kernel32_close_handle:
    push ax
    push bx
    
    ; Use DOS file functions
    mov ah, 0x3E        ; Close file
    mov bx, [file_handle]  ; File handle
    int 0x21
    jc .error
    
    ; Success
    xor ax, ax
    jmp .done
    
.error:
    mov ax, 0xFFFF      ; Error indicator
    
.done:
    pop bx
    pop ax
    ret

; =============================================================================
; kernel32_print_string: Print string using BIOS
; Input: SI = pointer to string
; =============================================================================
kernel32_print_string:
    push ax
    push si
    
.print_loop:
    lodsb
    cmp al, 0
    je .done
    
    mov ah, 0x0E        ; BIOS teletype output
    int 0x10
    jmp .print_loop
    
.done:
    pop si
    pop ax
    ret

; =============================================================================
; kernel32_update_tick: Update tick counter (called by timer interrupt)
; =============================================================================
kernel32_update_tick:
    inc word [tick_counter]
    ret

; =============================================================================
; Messages
; =============================================================================
kernel32_init_msg  db 'KERNEL32.DLL initialized (16-bit mode)', 0x0D, 0x0A, 0

kernel32_end:
    db 'END', 0, 0, 0         ; End marker
