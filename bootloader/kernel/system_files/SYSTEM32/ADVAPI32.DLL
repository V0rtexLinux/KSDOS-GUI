; =============================================================================
; ADVAPI32.DLL - Advanced Windows 32 Base API
; Provides advanced Windows API functions for registry, security, etc.
; =============================================================================

org 0x1000

; ---- ADVAPI32 header ----
db 'ADV ', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd advapi32_start              ; Entry point
dd advapi32_end - advapi32_start  ; Size
dd 0x00000000                  ; Reserved

advapi32_start:
    ; Advanced API functions initialization
    ret

advapi32_end:
    db 'END', 0, 0, 0         ; End marker
