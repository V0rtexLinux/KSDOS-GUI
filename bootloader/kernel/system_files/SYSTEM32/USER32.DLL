; =============================================================================
; USER32.DLL - Windows 32 User Interface API (16-bit Real Mode)
; User interface functions for windows, menus, dialogs, etc.
; =============================================================================

org 0x1000

; ---- USER32 header ----
db 'USR ', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dw user32_start                ; Entry point (16-bit offset)
dw user32_end - user32_start     ; Size
dd 0x00000000                  ; Reserved

; ---- Function table ----
function_table:
    dw user32_message_box      ; Function 0: Message box
    dw user32_create_window     ; Function 1: Create window
    dw user32_show_window      ; Function 2: Show window
    dw user32_destroy_window   ; Function 3: Destroy window
    dw user32_get_message      ; Function 4: Get message
    dw user32_translate_message ; Function 5: Translate message
    dw user32_dispatch_message  ; Function 6: Dispatch message
    dw user32_post_quit_message ; Function 7: Post quit message
    dw user32_def_window_proc  ; Function 8: Default window procedure
    dw user32_load_cursor      ; Function 9: Load cursor
    dw user32_set_cursor       ; Function 10: Set cursor
    dw user32_get_cursor_pos   ; Function 11: Get cursor position
    dw user32_set_cursor_pos   ; Function 12: Set cursor position
    dw user32_get_key_state    ; Function 13: Get key state
    dw user32_get_async_key_state ; Function 14: Get async key state
    dw user32_message_beep     ; Function 15: Message beep
    dw user32_get_system_metrics ; Function 16: Get system metrics

function_count equ 17

; ---- Data structures ----
window_list     dw 0
current_window  dw 0
message_queue   dw 32 dup(0)    ; Simple message queue
queue_head      dw 0
queue_tail      dw 0
cursor_handle   dw 0
cursor_x        dw 0
cursor_y        dw 0

; ---- Window class structure ----
window_class:
    style           dw 0
    lpfn_wnd_proc   dw 0
    cb_cls_extra     dw 0
    cb_wnd_extra     dw 0
    h_instance      dw 0
    h_icon          dw 0
    h_cursor        dw 0
    hbr_background  dw 0
    lpsz_menu_name   dw 0
    lpsz_class_name dw 0

; ---- Message structure ----
message_struct:
    hwnd            dw 0
    message         dw 0
    wparam          dw 0
    lparam_low       dw 0
    lparam_high      dw 0
    time            dw 0
    pt_x            dw 0
    pt_y            dw 0

; ---- Message constants ----
WM_NULL          equ 0x0000
WM_CREATE        equ 0x0001
WM_DESTROY       equ 0x0002
WM_MOVE          equ 0x0003
WM_SIZE          equ 0x0005
WM_ACTIVATE      equ 0x0006
WM_SETFOCUS      equ 0x0007
WM_KILLFOCUS     equ 0x0008
WM_ENABLE        equ 0x000A
WM_SETREDRAW     equ 0x000B
WM_SETTEXT       equ 0x000C
WM_GETTEXT       equ 0x000D
WM_GETTEXTLENGTH equ 0x000E
WM_PAINT         equ 0x000F
WM_CLOSE         equ 0x0010
WM_QUIT          equ 0x0012
WM_ERASEBKGND    equ 0x0014
WM_SYSCOMMAND    equ 0x0112
WM_KEYDOWN       equ 0x0100
WM_KEYUP         equ 0x0101
WM_CHAR          equ 0x0102
WM_MOUSEMOVE     equ 0x0200
WM_LBUTTONDOWN   equ 0x0201
WM_LBUTTONUP     equ 0x0202
WM_RBUTTONDOWN   equ 0x0204
WM_RBUTTONUP     equ 0x0205

; ---- Message box constants ----
MB_OK            equ 0x0000
MB_OKCANCEL      equ 0x0001
MB_ABORTRETRYIGNORE equ 0x0002
MB_YESNOCANCEL   equ 0x0003
MB_YESNO         equ 0x0004
MB_RETRYCANCEL   equ 0x0005
MB_ICONHAND      equ 0x0010
MB_ICONQUESTION  equ 0x0020
MB_ICONEXCLAMATION equ 0x0030
MB_ICONASTERISK  equ 0x0040

IDOK             equ 1
IDCANCEL         equ 2
IDABORT          equ 3
IDRETRY          equ 4
IDIGNORE         equ 5
IDYES            equ 6
IDNO             equ 7

user32_start:
    ; Initialize USER32
    call user32_init
    
    ; Return success
    xor ax, ax
    ret

; =============================================================================
; user32_init: Initialize USER32 library
; =============================================================================
user32_init:
    push ax
    push si
    
    ; Initialize window list
    mov [window_list], 0
    mov [current_window], 0
    
    ; Initialize message queue
    mov [queue_head], 0
    mov [queue_tail], 0
    
    ; Initialize cursor
    mov [cursor_handle], 0
    mov [cursor_x], 0
    mov [cursor_y], 0
    
    ; Display initialization message
    mov si, user32_init_msg
    call user32_print_string
    
    pop si
    pop ax
    ret

; =============================================================================
; user32_message_box: Display message box
; Input: AX = parent window, SI = text pointer, DI = caption pointer, BX = style
; Output: AX = result (IDOK, IDCANCEL, etc.)
; =============================================================================
user32_message_box:
    push ax
    push bx
    push si
    push di
    
    ; Clear screen for message box
    call user32_clear_screen
    
    ; Draw message box border
    call user32_draw_message_box
    
    ; Display caption
    mov si, di
    call user32_print_string
    
    ; Display message text
    mov si, [message_struct + 2]  ; Get text pointer
    call user32_print_string
    
    ; Wait for key press
    call user32_wait_key
    
    ; Return OK for now
    mov ax, IDOK
    
    pop di
    pop si
    pop bx
    pop ax
    ret

; =============================================================================
; user32_create_window: Create window
; Input: AX = class handle, SI = title pointer, BX = style, CX = x, DX = y
; Output: AX = window handle
; =============================================================================
user32_create_window:
    push ax
    push bx
    push cx
    push dx
    push si
    
    ; Simple window creation
    mov [current_window], ax
    
    ; Store window position
    mov [cursor_x], cx
    mov [cursor_y], dx
    
    ; Display creation message
    mov si, user32_window_created_msg
    call user32_print_string
    
    pop si
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; =============================================================================
; user32_show_window: Show window
; Input: AX = window handle, BX = show command
; =============================================================================
user32_show_window:
    push ax
    push bx
    
    ; Simple show window
    mov [current_window], ax
    
    ; Draw window
    call user32_draw_window
    
    pop bx
    pop ax
    ret

; =============================================================================
; user32_destroy_window: Destroy window
; Input: AX = window handle
; =============================================================================
user32_destroy_window:
    push ax
    
    ; Simple destroy window
    mov [current_window], 0
    
    ; Clear screen
    call user32_clear_screen
    
    pop ax
    ret

; =============================================================================
; user32_get_message: Get message from queue
; Input: SI = message structure pointer
; Output: AX = 0 if no message, 1 if message
; =============================================================================
user32_get_message:
    push ax
    push bx
    push si
    
    ; Check if queue is empty
    mov bx, [queue_head]
    cmp bx, [queue_tail]
    je .empty
    
    ; Get message from queue
    mov si, [message_queue + bx]
    inc bx
    inc bx
    cmp bx, 64
    jl .no_wrap
    
    xor bx, bx
    
.no_wrap:
    mov [queue_head], bx
    mov ax, 1    ; Message available
    jmp .done
    
.empty:
    xor ax, ax    ; No message
    
.done:
    pop si
    pop bx
    pop ax
    ret

; =============================================================================
; user32_translate_message: Translate message
; Input: SI = message structure pointer
; Output: AX = 0 if not translated, 1 if translated
; =============================================================================
user32_translate_message:
    ; Simple translation - always return not translated
    xor ax, ax
    ret

; =============================================================================
; user32_dispatch_message: Dispatch message to window procedure
; Input: SI = message structure pointer
; Output: AX = result from window procedure
; =============================================================================
user32_dispatch_message:
    push ax
    push si
    
    ; Get message type
    mov ax, [si + 2]  ; message field
    
    ; Call appropriate handler
    cmp ax, WM_PAINT
    je .handle_paint
    cmp ax, WM_KEYDOWN
    je .handle_keydown
    cmp ax, WM_DESTROY
    je .handle_destroy
    
    ; Default handling
    jmp .default
    
.handle_paint:
    call user32_handle_paint
    jmp .done
    
.handle_keydown:
    call user32_handle_keydown
    jmp .done
    
.handle_destroy:
    call user32_handle_destroy
    jmp .done
    
.default:
    call user32_def_window_proc
    
.done:
    pop si
    pop ax
    ret

; =============================================================================
; user32_post_quit_message: Post quit message
; Input: AX = exit code
; =============================================================================
user32_post_quit_message:
    push ax
    
    ; Add WM_QUIT to queue
    mov ax, WM_QUIT
    call user32_post_message
    
    pop ax
    ret

; =============================================================================
; user32_def_window_proc: Default window procedure
; Input: SI = message structure pointer
; Output: AX = result
; =============================================================================
user32_def_window_proc:
    ; Default procedure - return 0
    xor ax, ax
    ret

; =============================================================================
; user32_load_cursor: Load cursor
; Input: AX = cursor ID
; Output: AX = cursor handle
; =============================================================================
user32_load_cursor:
    ; Return default cursor
    mov ax, 1
    ret

; =============================================================================
; user32_set_cursor: Set cursor
; Input: AX = cursor handle
; Output: AX = previous cursor handle
; =============================================================================
user32_set_cursor:
    push ax
    
    mov ax, [cursor_handle]
    mov [cursor_handle], ax
    
    pop ax
    ret

; =============================================================================
; user32_get_cursor_pos: Get cursor position
; Output: CX = X, DX = Y
; =============================================================================
user32_get_cursor_pos:
    mov cx, [cursor_x]
    mov dx, [cursor_y]
    ret

; =============================================================================
; user32_set_cursor_pos: Set cursor position
; Input: CX = X, DX = Y
; =============================================================================
user32_set_cursor_pos:
    mov [cursor_x], cx
    mov [cursor_y], dx
    ret

; =============================================================================
; user32_get_key_state: Get key state
; Input: AL = virtual key code
; Output: AX = key state (bit 15 = key down)
; =============================================================================
user32_get_key_state:
    ; Simple implementation
    xor ax, ax
    ret

; =============================================================================
; user32_get_async_key_state: Get async key state
; Input: AL = virtual key code
; Output: AX = key state (bit 15 = key down)
; =============================================================================
user32_get_async_key_state:
    ; Use BIOS to check key state
    mov ah, 0x02
    int 0x16
    ret

; =============================================================================
; user32_message_beep: Play system beep
; =============================================================================
user32_message_beep:
    push ax
    
    ; Simple beep using BIOS
    mov ah, 0x0E
    mov al, 0x07    ; Bell character
    int 0x10
    
    pop ax
    ret

; =============================================================================
; user32_get_system_metrics: Get system metrics
; Input: AX = metric index
; Output: AX = metric value
; =============================================================================
user32_get_system_metrics:
    ; Return some common metrics
    cmp ax, 0    ; SM_CXSCREEN
    je .screen_width
    cmp ax, 1    ; SM_CYSCREEN
    je .screen_height
    
    ; Default
    xor ax, ax
    ret
    
.screen_width:
    mov ax, 80    ; 80 columns
    ret
    
.screen_height:
    mov ax, 25    ; 25 rows
    ret

; =============================================================================
; user32_post_message: Post message to queue
; Input: AX = message
; =============================================================================
user32_post_message:
    push ax
    push bx
    
    ; Add to queue (simplified)
    mov bx, [queue_tail]
    mov [message_queue + bx], ax
    inc bx
    inc bx
    cmp bx, 64
    jl .no_wrap
    
    xor bx, bx
    
.no_wrap:
    mov [queue_tail], bx
    
    pop bx
    pop ax
    ret

; =============================================================================
; user32_handle_paint: Handle WM_PAINT message
; =============================================================================
user32_handle_paint:
    ; Simple paint handler
    call user32_draw_window
    xor ax, ax
    ret

; =============================================================================
; user32_handle_keydown: Handle WM_KEYDOWN message
; =============================================================================
user32_handle_keydown:
    ; Simple keydown handler
    xor ax, ax
    ret

; =============================================================================
; user32_handle_destroy: Handle WM_DESTROY message
; =============================================================================
user32_handle_destroy:
    ; Post quit message
    mov ax, 0
    call user32_post_quit_message
    xor ax, ax
    ret

; =============================================================================
; user32_clear_screen: Clear screen
; =============================================================================
user32_clear_screen:
    push ax
    push bx
    push cx
    push dx
    
    ; Use BIOS to clear screen
    mov ax, 0x0600
    mov bh, 0x07
    mov cx, 0x0000
    mov dx, 0x184F
    int 0x10
    
    ; Set cursor to (0,0)
    mov ah, 0x02
    mov bh, 0x00
    mov dx, 0x0000
    int 0x10
    
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; =============================================================================
; user32_draw_message_box: Draw message box border
; =============================================================================
user32_draw_message_box:
    push ax
    push bx
    push cx
    push dx
    
    ; Draw simple box
    mov ah, 0x09
    mov al, '+'
    mov bh, 0x07
    mov cx, 1
    int 0x10
    
    ; Draw corners and edges (simplified)
    mov al, '-'
    mov cx, 20
.draw_top:
    int 0x10
    loop .draw_top
    
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; =============================================================================
; user32_draw_window: Draw window
; =============================================================================
user32_draw_window:
    push ax
    push bx
    push cx
    push dx
    
    ; Draw window border
    mov ah, 0x09
    mov al, '+'
    mov bh, 0x07
    mov cx, 1
    int 0x10
    
    ; Draw window title bar
    mov al, '='
    mov cx, 30
.draw_title:
    int 0x10
    loop .draw_title
    
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; =============================================================================
; user32_wait_key: Wait for key press
; =============================================================================
user32_wait_key:
    push ax
    
.wait_loop:
    mov ah, 0x01
    int 0x16
    jz .wait_loop
    
    mov ah, 0x00
    int 0x16
    
    pop ax
    ret

; =============================================================================
; user32_print_string: Print string using BIOS
; Input: SI = pointer to string
; =============================================================================
user32_print_string:
    push ax
    push si
    
.print_loop:
    lodsb
    cmp al, 0
    je .done
    
    mov ah, 0x0E
    int 0x10
    jmp .print_loop
    
.done:
    pop si
    pop ax
    ret

; =============================================================================
; Messages
; =============================================================================
user32_init_msg             db 'USER32.DLL initialized (16-bit mode)', 0x0D, 0x0A, 0
user32_window_created_msg  db 'Window created successfully', 0x0D, 0x0A, 0

user32_end:
    db 'END', 0, 0, 0         ; End marker
