; =============================================================================
; GLU32.DLL - OpenGL Utility Library
; Helper functions for OpenGL operations
; =============================================================================

org 0x1000

; ---- GLU32 header ----
db 'GLU ', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd glu32_start                 ; Entry point
dd glu32_end - glu32_start      ; Size
dd 0x00000000                  ; Reserved

glu32_start:
    ; GLU initialization
    ret

glu32_end:
    db 'END', 0, 0, 0         ; End marker
