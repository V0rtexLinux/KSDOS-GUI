; =============================================================================
; COMDLG32.DLL - Common Dialog Library
; Common dialog boxes like file open, save, print, etc.
; =============================================================================

org 0x1000

; ---- COMDLG32 header ----
db 'COMD', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd comdlg32_start              ; Entry point
dd comdlg32_end - comdlg32_start  ; Size
dd 0x00000000                  ; Reserved

comdlg32_start:
    ; Common dialog initialization
    ret

comdlg32_end:
    db 'END', 0, 0, 0         ; End marker
