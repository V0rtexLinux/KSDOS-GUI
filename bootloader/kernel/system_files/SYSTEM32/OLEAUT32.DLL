; =============================================================================
; OLEAUT32.DLL - OLE Automation
; Automation support for COM objects and scripting
; =============================================================================

org 0x1000

; ---- OLEAUT32 header ----
db 'OLEA', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd oleaut32_start              ; Entry point
dd oleaut32_end - oleaut32_start  ; Size
dd 0x00000000                  ; Reserved

oleaut32_start:
    ; OLE automation initialization
    ret

oleaut32_end:
    db 'END', 0, 0, 0         ; End marker
