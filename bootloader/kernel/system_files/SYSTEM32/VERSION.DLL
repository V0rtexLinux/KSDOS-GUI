; =============================================================================
; VERSION.DLL - Version Information API
; File version and resource functions
; =============================================================================

org 0x1000

; ---- VERSION header ----
db 'VERS', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd version_start               ; Entry point
dd version_end - version_start  ; Size
dd 0x00000000                  ; Reserved

version_start:
    ; Version API initialization
    ret

version_end:
    db 'END', 0, 0, 0         ; End marker
