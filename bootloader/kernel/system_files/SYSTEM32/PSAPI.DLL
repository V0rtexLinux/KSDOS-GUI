; =============================================================================
; PSAPI.DLL - Process Status API
; Process and memory status functions
; =============================================================================

org 0x1000

; ---- PSAPI header ----
db 'PSAP', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd psapi_start                 ; Entry point
dd psapi_end - psapi_start      ; Size
dd 0x00000000                  ; Reserved

psapi_start:
    ; Process status API initialization
    ret

psapi_end:
    db 'END', 0, 0, 0         ; End marker
